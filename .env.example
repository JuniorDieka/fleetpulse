# FleetPulse Environment Variables
# Copy this file to .env and customize as needed

# Airflow
AIRFLOW_UID=50000

# Alert Webhook (optional)
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WEBHOOK_URL

# Database
DUCKDB_PATH=./data/warehouse/fleetpulse.duckdb

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
